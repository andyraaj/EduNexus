# EduNexus ERP - Environment Configuration Example
# Copy this file to .env and configure for your deployment

# ============================================================
# NODE ENVIRONMENT
# ============================================================
# development = local dev with hot reload, debug logging
# production = optimized, security-hardened, minimal logging
NODE_ENV=production

# ============================================================
# SERVER CONFIGURATION
# ============================================================
# Port the Express server listens on
PORT=5000

# ============================================================
# DATABASE
# ============================================================
# MongoDB Atlas Connection URI (production)
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/EduNexus?retryWrites=true&w=majority
# Local development: mongodb://127.0.0.1:27017/EduNexus
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/EduNexus?retryWrites=true&w=majority

# Optional: Redis URL for rate limiting and caching
# REDIS_URL=redis://localhost:6379
# For production with external Redis: redis://username:password@host:port

# ============================================================
# AUTHENTICATION
# ============================================================
# JWT Secret - MUST be long, random, and unique per environment
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Use a minimum 32 character random string
JWT_SECRET=your_long_random_secret_key_here_at_least_32_chars

# JWT Access Token Expiration (short-lived)
JWT_ACCESS_EXPIRES=15m

# JWT Refresh Token Expiration (long-lived)
JWT_REFRESH_EXPIRES=7d

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
# Client origin(s) for CORS validation
# For single domain: http://yourdomain.com
# For multiple: http://yourdomain.com,https://yourdomain.com,https://www.yourdomain.com
# Important: Must include https:// in production
CLIENT_ORIGIN=https://yourdomain.com

# ============================================================
# RATE LIMITING
# ============================================================
# Requests per minute per IP (default: 240)
RATE_LIMIT_PER_MINUTE=240

# Disable rate limiting for development/testing only
# DISABLE_RATE_LIMIT=false

# ============================================================
# CLOUDINARY — Cloud File Storage (REQUIRED)
# ============================================================
# All uploaded files (PDFs, images, course materials) are stored
# on Cloudinary. No local disk writes occur — uploads survive redeploys.
#
# Get your credentials from: https://cloudinary.com/console
# Cloud Name is visible on the Cloudinary dashboard.
# API Key and Secret are under Settings → Access Keys.
#
# REQUIRED in production. Missing values cause server startup failure.
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================================
# EMAIL CONFIGURATION (Optional - for notifications)
# ============================================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@EduNexus.com

# ============================================================
# LOGGING
# ============================================================
# Log level: error, warn, info, debug
# LOG_LEVEL=info

# ============================================================
# SECURITY
# ============================================================
# Enable/disable CSRF protection (always on in production)
# CSRF_ENABLED=true

# ============================================================
# ADVANCED
# ============================================================
# Node.js workers for clustering (production optimization)
# CLUSTER_WORKERS=auto
